# SQL Server
SA_PASSWORD=YourStrong@Passw0rd

# JWT (generate a secure key: openssl rand -hex 32)
JWT__KEY=your-256-bit-secret-key-here-change-in-production
JWT__ISSUER=ECommerceApi
JWT__AUDIENCE=ECommerceClient

# Stripe (get from https://dashboard.stripe.com/test/apikeys)
STRIPE__SECRETKEY=sk_test_xxxxxxxxxxxxxxxxxxxx
STRIPE__PUBLISHABLEKEY=pk_test_xxxxxxxxxxxxxxxxxxxx
STRIPE__WEBHOOKSECRET=whsec_xxxxxxxxxxxxxxxxxxxx

# SendGrid (get from https://app.sendgrid.com/settings/api_keys)
SENDGRID__APIKEY=SG.xxxxxxxxxxxxxxxxxxxx
SENDGRID__FROMEMAIL=noreply@example.com
SENDGRID__FROMNAME=BMJ Store

# CORS (frontend origin, defaults to http://localhost:80)
CORS_ORIGIN=http://localhost:80

# Frontend API URL (defaults to http://localhost:8080)
VITE_API_URL=http://localhost:8080

# Frontend URL for password reset links
FRONTEND_URL=http://localhost:80

# Seq (optional structured logging)
# SEQ_URL=http://seq:5341
